# Build output (compiled binaries) — but keep the committed shell shim.
/bin/*
!/bin/.gitkeep
!/bin/scrimward-py
dist/
build/
*.o
*.a

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.pytest_cache/
.venv/
venv/

# Go
/vendor/
*.test
*.out

# Swift / Xcode
.build/
*.swiftpm
DerivedData/

# Node
node_modules/

# Local runtime state (NEVER commit — may contain real secrets)
*.vault.json
vault-*.json
redact.log
config/rules.json
.env
.env.*

# macOS
.DS_Store

# Editor
.idea/
.vscode/
*.swp
